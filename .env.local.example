# Copia este archivo a .env.local y reemplaza los valores con tus credenciales.
# Para obtener un Client ID de Google, crea un proyecto en https://console.cloud.google.com/apis/credentials
# y agrega un OAuth 2.0 Client ID con tipo "Aplicación web" y origen autorizado http://localhost:3000

NEXT_PUBLIC_GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
